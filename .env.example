# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=survey_user
DB_PASSWORD=replace-with-strong-password
DB_NAME=survey_db

# Backend
PORT=3001
NODE_ENV=production
CORS_ORIGIN=https://example.com
ADMIN_TOKEN=replace-with-random-admin-token

# Optional but recommended when using a domain
PUBLIC_BASE=https://example.com

# If frontend and backend are on the same domain behind Nginx, keep this empty.
VITE_API_BASE_URL=

# Optional AI
DS_API_KEY=
DS_API_URL=https://api.deepseek.com

# Optional switches
DISABLE_DB=false
ADMIN_TOKEN_HASH=
