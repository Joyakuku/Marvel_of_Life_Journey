/* survey.wxss */
page {
  height: 100vh; /* 确保页面占满整个视口高度 */
}

.page-wrapper {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.scrollarea {
  flex: 1; /* 占据剩余的所有空间 */
  overflow-y: auto; /* 允许自身滚动 */
  -webkit-overflow-scrolling: touch; /* iOS 滚动优化 */
}

.container {
  padding: 20rpx;
  padding-bottom: 40rpx; /* 恢复正常内边距 */
  background-color: #f5f5f5;
}

.questions-container {
  margin-bottom: 40rpx;
}

.question-item {
  background: white;
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}



.question-title {
  display: flex;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.question-number {
  font-size: 32rpx;
  font-weight: bold;
  color: #007aff;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.question-text {
  font-size: 32rpx;
  color: #333;
  line-height: 1.5;
  flex: 1;
}

.required-mark {
  color: #ff3b30;
  font-size: 32rpx;
  margin-left: 10rpx;
}

.options-container {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option-item {
  padding: 20rpx 0;
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
  border-radius: 8rpx;
  transition: background-color 0.2s ease;
}

.option-item:active {
  background-color: rgba(0, 122, 255, 0.1);
}

.radio-wrapper,
.checkbox-wrapper {
  display: flex;
  align-items: center;
  width: 100%;
  min-height: 44rpx;
  cursor: pointer;
}

.radio,
.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ddd;
  margin-right: 20rpx;
  flex-shrink: 0;
  position: relative;
}

.radio {
  border-radius: 50%;
}

.checkbox {
  border-radius: 8rpx;
}

.radio-checked {
  border-color: #007aff;
  background-color: #007aff;
}

.radio-checked::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 16rpx;
  height: 16rpx;
  background-color: white;
  border-radius: 50%;
}

.checkbox-checked {
  border-color: #007aff;
  background-color: #007aff;
}

.checkbox-checked::after {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 12rpx;
  width: 12rpx;
  height: 20rpx;
  border: 3rpx solid white;
  border-top: none;
  border-left: none;
  transform: rotate(45deg);
}

.option-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.5;
  flex: 1;
}

.text-input-container {
  margin-top: 10rpx;
  margin-bottom: 20rpx; /* 增加底部边距 */
}

.text-input {
  width: 100%;
  min-height: 200rpx; /* 增加最小高度 */
  max-height: 400rpx; /* 设置最大高度 */
  padding: 20rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
  background-color: #fafafa;
  box-sizing: border-box;
  overflow-y: auto; /* 超出高度时显示滚动条 */
}

.text-input:focus {
  border-color: #007aff;
  background-color: white;
}

.submit-container {
  padding: 20rpx 0 40rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #007aff 0%, #5856d6 100%);
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(0, 122, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 122, 255, 0.3);
}

/* 固定底部提交按钮容器 */
.fixed-bottom-container {
  /* position: fixed; 已移除，现在是 flex item */
  flex-shrink: 0; /* 防止被压缩 */
  background: white;
  padding: 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 1000;
}

.remaining-info {
  flex: 1;
}

.remaining-text {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.fixed-submit-btn {
  width: 200rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #007aff 0%, #5856d6 100%);
  color: white;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 36rpx;
  border: none;
  box-shadow: 0 6rpx 18rpx rgba(0, 122, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
}

.fixed-submit-btn:active {
  transform: translateY(1rpx);
  box-shadow: 0 3rpx 9rpx rgba(0, 122, 255, 0.3);
}