/**index.wxss**/
.scrollarea {
  height: 100vh;
  box-sizing: border-box;
}

.container {
  padding: 20rpx;
  background: #ffffff;
  min-height: 100vh;
}

/* 欢迎区域 */
.welcome-section {
  text-align: center;
  padding: 60rpx 30rpx 0;
  color: #000000;
}

.welcome-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.welcome-desc {
  display: block;
  font-size: 28rpx;
  opacity: 0.7;
  line-height: 1.5;
}

/* 问卷卡片 */
.survey-card {
  background: #ffffff;
  padding: 40rpx 30rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  border: 1px solid #e0e0e0;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #000000;
}

.card-badge {
  background: #000000;
  color: #ffffff;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.card-desc {
  display: block;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
  margin-bottom: 30rpx;
}

.card-features {
  display: flex;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.feature-icon {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.feature-text {
  font-size: 24rpx;
  color: #333333;
  text-align: center;
}

.start-survey-btn {
  width: 100%;
  height: 88rpx;
  background: #000000;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.start-survey-btn:active {
  background: #333333;
}

/* 说明区域 */
.info-section {
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.info-text {
  display: block;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
  text-align: justify;
  text-indent: 2em;
}

.info-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #000000;
  margin-bottom: 24rpx;
}

.info-list {
  display: inline-flex;
  flex-direction: column;
  gap: 16rpx;
  text-align: left;
}

.info-item {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.5;
}
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}
.scrollarea {
  flex: 1;
  overflow-y: hidden;
}
