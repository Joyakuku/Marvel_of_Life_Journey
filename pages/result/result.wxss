/* result.wxss */
.scrollarea {
  height: 100vh;
  box-sizing: border-box;
}

.container {
  padding: 20rpx;
  background: #FFFFFF;
  min-height: 100vh;
}

/* 结果头部 */
.result-header {
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

/* 新增：模式切换条 */
/* 固定的模式切换外层：固定在导航栏下方 */
.mode-switch-fixed {
  position: fixed; /* 始终固定 */
  left: 0;
  right: 0;
  z-index: 98; /* 低于弹窗，高于页面内容 */
  padding: 8rpx 20rpx; /* 左右留白贴边更自然 */
  background: linear-gradient(180deg, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0.85) 100%);
  backdrop-filter: blur(6px); /* 半透明毛玻璃，提升高级感 */
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.06); /* 轻阴影，分层更明显 */
}

/* 固定切换条在内容区的占位高度，防止遮挡 */
.switch-spacer {
  height: 104rpx; /* 默认占位，高度可在页面计算覆盖 */
}

/* 新版：模式切换条（胶囊 + 渐变） */
.mode-switch {
  display: flex;
  gap: 12rpx;
  background: #f6f7fb;
  padding: 10rpx;
  border-radius: 999rpx;
  border: 1rpx solid #eef1ff;
}

/* 切换按钮：渐变激活 + 轻边框 */
.switch-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 26rpx;
  color: #5f6b84;
  border-radius: 999rpx;
  background: #fff; /* 未激活：白底 */
  border: 1rpx solid #e9ecf6;
  transition: all 200ms ease; /* 平滑切换 */
}

.switch-btn.active {
  background: linear-gradient(135deg, #667eea 0%, #7f9cf5 100%);
  color: #ffffff;
  font-weight: 600;
  box-shadow: 0 8rpx 18rpx rgba(102, 126, 234, 0.25);
  border-color: transparent;
}

/* 轻微按压态，提升可点击感受 */
.switch-btn:active {
  transform: scale(0.98);
}

/* 移除重复的旧激活样式，避免覆盖新的渐变效果 */

.success-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  border-radius: 50%;
  margin: 0 auto 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(76, 175, 80, 0.3);
}

.icon-check {
  font-size: 40rpx;
  color: white;
  font-weight: bold;
}

.success-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.success-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 30rpx;
}

.submit-time {
  display: block;
  font-size: 22rpx;
  color: #999;
  background: #f8f9fa;
  padding: 12rpx 20rpx;
  border-radius: 16rpx;
  display: inline-block;
}

/* 总分概览：两列布局（压缩高度） */
.score-summary.two-col {
  display: flex;              /* 左右两栏 */
  gap: 20rpx;                 /* 两栏间距 */
  align-items: stretch;       /* 拉齐高度 */
  text-align: left;           /* 统一左对齐，左列内部再居中分数 */
}
.score-summary.two-col .col {
  flex: 1;                    /* 两栏平均分布 */
  min-width: 0;               /* 防止换行导致溢出 */
}
.score-summary.two-col .left {
  display: flex;
  flex-direction: column;
  align-items: center;        /* 分数盒子水平居中 */
}
.score-summary.two-col .right {
  display: flex;
  flex-direction: column;
  justify-content: center;    /* 文案垂直居中，更紧凑 */
}
/* 压缩内部间距：标题与等级文案 */
.score-summary.two-col .score-title { margin-bottom: 6rpx; }
.score-summary.two-col .level-text { margin-top: 0; }
.score-summary.two-col .level-desc { margin-top: 4rpx; }
.score-title {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}

.score-box {
  display: inline-flex;
  align-items: flex-end;
  justify-content: center;
  padding: 18rpx 28rpx;
  background: #eef2ff;
  border: 1rpx solid #dbe2ff;
  border-radius: 16rpx;
}

.score {
  font-size: 40rpx;
  font-weight: 700;
  color: #3b5bdb;
}

.slash {
  margin: 0 8rpx;
  font-size: 32rpx;
  color: #8aa0ff;
}

.max-score {
  font-size: 28rpx;
  color: #8aa0ff;
}

.level-summary {
  margin-top: 12rpx;
}

.level-text {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-top: 8rpx;
}

.level-desc {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  margin-top: 6rpx;
}

/* AI解析容器 */
.ai-analysis-container {
  margin-bottom: 40rpx;
}

/* 统一为与 .result-list 相同的卡片外观 */
.ai-analysis-box {
  background: #ffffff; /* 与结果列表一致的白底 */
  border: 1rpx solid #eef0f3; /* 与结果列表一致的描边 */
  border-radius: 12rpx; /* 与结果列表一致的圆角 */
  padding: 20rpx; /* 与结果列表一致的内边距 */
}

/* 头部与题目标题风格统一：左对齐，留出间距 */
.ai-analysis-header {
  margin-bottom: 12rpx;
  text-align: left; /* 统一左对齐 */
}

/* 标题尺寸与 q-title 接近，保留品牌色突出“AI” */
.ai-title {
  font-size: 28rpx; /* 统一字号 */
  font-weight: 600;
  color: #667eea;
  display: block;
}

/* 内容块统一为“解析”卡片样式（淡紫底 + 虚线边框） */
.ai-analysis-content {
  min-height: 160rpx;
  background: #fafbff; /* 与 .q-explanation 保持一致 */
  border: 1rpx dashed #e3e7ff; /* 与 .q-explanation 保持一致 */
  border-radius: 8rpx; /* 与 .q-explanation 保持一致 */
  padding: 12rpx; /* 与 .q-explanation 保持一致 */
  display: block; /* 统一为普通文流布局 */
}

.ai-placeholder {
  text-align: left; /* 与解析文本对齐方式一致 */
  padding: 0; /* 外层已有 padding，这里置 0 避免双倍间距 */
}

/* 文案风格统一为解析内容的字号与颜色 */
.placeholder-text {
  font-size: 24rpx; /* 与 .q-explanation .content 接近 */
  color: #555; /* 与解析内容颜色一致 */
  line-height: 1.6;
}



/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.primary-btn {
  background: #667eea;
  color: white;
}

.secondary-btn {
  background: #f5f5f5;
  color: #666;
  border: 1rpx solid #e0e0e0;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 28rpx;
}

.action-btn:active {
  opacity: 0.8;
}



/* 感谢信息 */
.thank-you {
  background: #f8f9fa;
  padding: 40rpx 30rpx;
  border-radius: 12rpx;
  text-align: center;
  border: 1rpx solid #e9ecef;
}

.thank-text {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.thank-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}


/* result.wxss */
/* 弹窗遮罩，确保与页面内容互不干扰 */
.submit-popup-mask {
  position: fixed;
  left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0,0,0,0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999; /* 高于页面内容 */
}

/* 弹窗容器 */
.submit-popup {
  width: 420rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 12rpx 40rpx rgba(0,0,0,0.15);
  padding: 36rpx 28rpx;
  text-align: center;
}

/* 成功图标：使用简化符号，后续可替换为 iconfont 或图片 */
.submit-popup__icon {
  width: 96rpx;
  height: 96rpx;
  line-height: 96rpx;
  margin: 0 auto 16rpx;
  border-radius: 50%;
  background: #35C759; /* iOS 绿 */
  color: #fff;
  font-size: 64rpx;
  font-weight: 600;
}

.submit-popup__title {
  font-size: 32rpx;
  color: #111;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.submit-popup__time {
  font-size: 24rpx;
  color: #666;
}

/* 以下为原页面样式占位（若已有则可合并） */
.result-page { padding: 24rpx; }
.header { margin-bottom: 24rpx; }
.title { font-size: 36rpx; font-weight: 700; }
.sub-title { font-size: 24rpx; color: #888; }
.score-summary { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 24rpx; }
.score-item { display: flex; align-items: baseline; }
.score { font-size: 56rpx; color: #111; font-weight: 700; }
.score-max { margin-left: 8rpx; color: #999; }
.level { margin-top: 12rpx; color: #333; }
.level-desc { margin-top: 6rpx; color: #666; }
.ai-section { padding: 24rpx; color: #666; }
.result-list { background: #fff; border-radius: 12rpx; padding: 16rpx; }
.result-item { padding: 16rpx 0; border-bottom: 1px solid #f0f0f0; }
.result-item:last-child { border-bottom: none; }
.question { font-weight: 600; color: #222; margin-bottom: 4rpx; }
.answer { color: #333; margin: 8rpx 0; }
.explanation { color: #666; font-size: 24rpx; }
.actions { margin: 24rpx 0; display: flex; gap: 16rpx; }
.footer { text-align: center; color: #999; margin-top: 16rpx; }

.result-list {
  background: #ffffff;
  border: 1rpx solid #eef0f3;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 40rpx;
}

.result-item {
  padding: 20rpx 10rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-item:last-child {
  border-bottom: none;
}

.q-title {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.q-answer {
  display: block;
  font-size: 26rpx;
  color: #667eea;
}

/* 解析样式 */
.q-explanation {
  margin-top: 8rpx;
  background: #fafbff;
  border: 1rpx dashed #e3e7ff;
  border-radius: 8rpx;
  padding: 12rpx;
}

.q-explanation .label {
  font-size: 24rpx;
  color: #888;
}

.q-explanation .content {
  font-size: 24rpx;
  color: #555;
  line-height: 1.6;
}


/* 页面顶部固定区（导航栏下，包含模式切换和总分概览） */
.page-fixed-top {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 9;
  padding: 12rpx 20rpx 16rpx;
  background: rgba(255, 255, 255, 0.86);
  backdrop-filter: blur(10px);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

/* 固定区内部的间距控制 */
.page-fixed-top .mode-switch { margin-bottom: 12rpx; }
.page-fixed-top .score-summary { margin: 0; }
/* 总分概览：两列布局以压缩高度 */
.score-summary.two-col {
  display: flex;
  gap: 16rpx;
  align-items: center; /* 垂直居中左右两块 */
  text-align: left;   /* 两列内部使用自身对齐 */
}

/* 让两列在窄屏下也能收缩，避免文本被撑开 */
.score-summary.two-col .summary-col { flex: 1; min-width: 0; }

/* 顶部固定区内收紧容器整体内边距，进一步压缩高度 */
.page-fixed-top .score-summary.two-col { padding: 16rpx; }
.score-summary.two-col .left .score-title { margin-bottom: 8rpx; }

/* 右侧文案紧凑展示 */
.score-summary.two-col .level-text { margin-top: 0; }
/* 取消右侧说明的两行截断，按用户要求全部展示 */
/* 覆盖上方 two-col 的截断样式：放在文件靠后，确保优先生效 */
.score-summary.two-col .level-desc {
/* 不再使用 -webkit-box 模式 */
display: block;            /* 不再使用 -webkit-box 模式 */
overflow: visible;         /* 允许完整展示 */
-webkit-line-clamp: unset; /* 取消行数限制 */
-webkit-box-orient: initial;
}

/* 固定区里的紧凑尺寸，进一步压缩高度 */
.page-fixed-top .score-summary.two-col .score-box { padding: 12rpx 20rpx; }
.page-fixed-top .score-summary.two-col .score { font-size: 36rpx; }
.page-fixed-top .score-summary.two-col .slash { font-size: 28rpx; }
.page-fixed-top .score-summary.two-col .max-score { font-size: 24rpx; }