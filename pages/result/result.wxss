/* result.wxss */
.scrollarea {
  height: 100vh;
  box-sizing: border-box;
}

.container {
  padding: 20rpx;
  background: #FFFFFF;
  min-height: 100vh;
}

/* 结果头部 */
.result-header {
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.success-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  border-radius: 50%;
  margin: 0 auto 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(76, 175, 80, 0.3);
}

.icon-check {
  font-size: 40rpx;
  color: white;
  font-weight: bold;
}

.success-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.success-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 30rpx;
}

.submit-time {
  display: block;
  font-size: 22rpx;
  color: #999;
  background: #f8f9fa;
  padding: 12rpx 20rpx;
  border-radius: 16rpx;
  display: inline-block;
}

/* AI解析容器 */
.ai-analysis-container {
  margin-bottom: 40rpx;
}

.ai-analysis-box {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 30rpx;
  border: 2rpx dashed #e0e0e0;
  position: relative;
}

.ai-analysis-header {
  margin-bottom: 20rpx;
  text-align: center;
}

.ai-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #667eea;
  display: block;
}

.ai-analysis-content {
  min-height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-placeholder {
  text-align: center;
  padding: 40rpx 20rpx;
}

.placeholder-text {
  font-size: 28rpx;
  color: #999;
  line-height: 1.5;
}



/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.primary-btn {
  background: #667eea;
  color: white;
}

.secondary-btn {
  background: #f5f5f5;
  color: #666;
  border: 1rpx solid #e0e0e0;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 28rpx;
}

.action-btn:active {
  opacity: 0.8;
}



/* 感谢信息 */
.thank-you {
  background: #f8f9fa;
  padding: 40rpx 30rpx;
  border-radius: 12rpx;
  text-align: center;
  border: 1rpx solid #e9ecef;
}

.thank-text {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.thank-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}